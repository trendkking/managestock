[Unit]
Description=BULLSLONG FastAPI backend
After=network.target

[Service]
Type=simple
User=ec2-user
WorkingDirectory=/var/www/bullslong/backend
EnvironmentFile=/var/www/bullslong/backend/.env
ExecStart=/var/www/bullslong/backend/venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 8000 --workers 2
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
